progenitor(bart, tina).

casado(homer, marge).

avo(A, N):- 
  progenitor(A,P), 
  progenitor(P,N).

irmao(B, C):-
  progenitor(P, B),
  progenitor(P, C), 
  B \= C.

tio(T, S) :- 
  irmao(T, I),
  progenitor(I, S).

cunhado(C, M) :- 
  casado(H, M),
  irmao(C, H).
cunhado(C, H) :- 
  casado(H, M),
  irmao(C, M).
