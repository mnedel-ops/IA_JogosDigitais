avo(A, N):- progenitor(A,P), progenitor(P,N).

irmao(B, C):- progenitor(P, B), progenitor(P, C), B \= C.

tio(T, S) :- irmao(I, T), progenitor(I, S).

casado(H, M) :- progenitor(H, F), progenitor(M, F).

cunhado(C, M) :- casado(H, M), irmao(C, H).
